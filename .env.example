# Giscus Comments (https://giscus.app)
# Get these values from https://giscus.app after setting up your GitHub repository
GISCUS_REPO=owner/repo-name
GISCUS_REPO_ID=your_repo_id
GISCUS_CATEGORY_ID=your_category_id

# Site URL (used for canonical URLs and OG tags)
PUBLIC_SITE_URL=https://your-domain.vercel.app
