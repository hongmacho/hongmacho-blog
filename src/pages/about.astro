---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { getCollection } from 'astro:content';
import { SETTINGS } from '@/lib/settings';

const allPosts = await getCollection('blog');
const postCount = allPosts.length;

const { about } = SETTINGS;
const statsResolved = about.stats.map((s) =>
  s.key === 'posts' && s.value === null ? { ...s, value: String(postCount) } : s,
);
---

<BaseLayout title={about.pageTitle} description={about.pageDescription}>
  <Header />
  <main id="main-content">
    <div class="about">
      <div class="about__hero">
        <span class="about__avatar" aria-hidden="true">{about.avatarChar}</span>
        <div>
          <h1 class="about__name">{about.name}</h1>
          <p class="about__role">{about.role}</p>
        </div>
      </div>

      <div class="prose">
        {about.intro.map((paragraph) => (
          <p set:html={paragraph} />
        ))}
      </div>

      <div class="about__stat-grid">
        {statsResolved.map((stat) => (
          <div class="about__stat">
            <div class="about__stat-value">{stat.value}</div>
            <div class="about__stat-label">{stat.label}</div>
          </div>
        ))}
      </div>

      <div class="prose">
        <h2>주로 다루는 주제</h2>
        <ul>
          {about.topics.map((topic) => (
            <li><strong>{topic.name}</strong> — {topic.desc}</li>
          ))}
        </ul>

        <h2>지금 관심 있는 것</h2>
        <ol>
          {about.interests.map((item) => (
            <li>{item}</li>
          ))}
        </ol>

        <h2>연락</h2>
        <p>
          {about.contact.intro}{' '}
          <a href={`mailto:${about.contact.email}`}>{about.contact.email}</a>{' '}
          {about.contact.outro}
        </p>
      </div>

      <div style="display:flex;gap:8px;margin-top:32px;flex-wrap:wrap">
        <a href={about.links.github} target="_blank" rel="noopener noreferrer" class="btn btn--ghost">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
          </svg>
          GitHub
        </a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
