---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Sidebar from '../../components/blog/Sidebar.astro';
import ListItem from '../../components/blog/ListItem.astro';
import TagCloud from '../../components/blog/TagCloud.astro';
import { getCollection } from 'astro:content';
import { CATEGORY_LIST } from '../../lib/categories';
import type { CategoryId } from '../../lib/categories';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const url = Astro.url;
const selectedCat = url.searchParams.get('cat') as CategoryId | null;
const selectedTag = url.searchParams.get('tag');

const filteredPosts = sortedPosts.filter((post) => {
  if (selectedCat && post.data.category !== selectedCat) return false;
  if (selectedTag && !post.data.tags.includes(selectedTag)) return false;
  return true;
});

const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags))];
const tagCounts = allTags.map((tag) => ({
  tag,
  count: allPosts.filter((p) => p.data.tags.includes(tag)).length,
})).sort((a, b) => b.count - a.count);

const categoryCounts = CATEGORY_LIST.map((cat) => ({
  ...cat,
  count: allPosts.filter((p) => p.data.category === cat.id).length,
}));

const headTitle = selectedTag
  ? `#${selectedTag}`
  : selectedCat
  ? `${CATEGORY_LIST.find((c) => c.id === selectedCat)?.name ?? ''} 글`
  : '전체 글';

const headSub = selectedTag
  ? `'${selectedTag}' 태그가 달린 글 ${filteredPosts.length}개`
  : `총 ${filteredPosts.length}개의 글`;
---

<BaseLayout title={`${headTitle} | 홍마초의 잡생각`}>
  <Header />
  <main id="main-content">
    <div class="page-head">
      <div class="container">
        <h1 class="page-head__title">{headTitle}</h1>
        <p class="page-head__sub">{headSub}</p>
      </div>
    </div>

    <div class="container blog-layout">
      <aside class="sidebar" aria-label="필터">
        <Sidebar categories={categoryCounts} selectedCat={selectedCat} />
        <TagCloud tags={tagCounts} selectedTag={selectedTag} />
      </aside>

      <div class="blog-list">
        {filteredPosts.length === 0 ? (
          <div style="padding:64px 0;text-align:center;color:var(--color-label-alternative)">
            해당 조건의 글이 아직 없습니다.
          </div>
        ) : (
          filteredPosts.map((post) => <ListItem post={post} />)
        )}
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
