---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<BaseLayout title="404 — 홍마초의 잡생각" description="페이지를 찾을 수 없습니다.">
  <Header />
  <main class="error-404" id="main-content">
    <div class="error-404__code" aria-hidden="true">404</div>
    <h1 class="error-404__title">페이지를 찾을 수 없어요</h1>
    <p class="error-404__sub">
      주소가 바뀌었거나, 글이 비공개로 전환됐을 수 있어요. 다른 글을 둘러보시는 건 어때요?
    </p>
    <div style="display:flex;gap:8px;margin-top:8px;flex-wrap:wrap;justify-content:center">
      <a href="/" class="btn btn--primary">
        홈으로
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 5l7 7-7 7" />
        </svg>
      </a>
      <a href="/blog" class="btn btn--ghost">블로그 둘러보기</a>
    </div>
  </main>
  <Footer />
</BaseLayout>
