---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import ListItem from '../components/blog/ListItem.astro';
import { getCollection } from 'astro:content';
import { searchPosts } from '../lib/search';
import type { BlogPost } from '../lib/search';

const allPosts = await getCollection('blog');

const blogPosts: BlogPost[] = allPosts.map((post) => ({
  id: post.id,
  title: post.data.title,
  excerpt: post.data.excerpt,
  category: post.data.category,
  tags: post.data.tags,
  date: typeof post.data.date === 'string' ? post.data.date : post.data.date.toISOString(),
  slug: post.id,
}));

const query = Astro.url.searchParams.get('q') || '';
const trimmed = query.trim();
const results = trimmed ? searchPosts(blogPosts, trimmed) : [];

const tagCounts = new Map<string, number>();
allPosts.forEach((post) => {
  post.data.tags.forEach((tag) => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});
const popularTags = Array.from(tagCounts.entries())
  .map(([tag, count]) => ({ tag, count }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 8);

const resultEntries = allPosts.filter((post) => results.some((r) => r.id === post.id));
---

<BaseLayout title={trimmed ? `"${trimmed}" 검색 결과 | 홍마초의 잡생각` : '검색'} description="검색 결과">
  <Header />
  <main id="main-content">
    <div class="container search-results-page">
      <div class="search-results-page__head">
        <div class="search-results-page__label">검색 결과</div>
        <h1 class="search-results-page__query">
          <span class="quote">"</span>{trimmed || '검색어 없음'}<span class="quote">"</span>
        </h1>
        <div class="search-results-page__count">
          {trimmed ? `${results.length}개의 결과` : '검색어를 입력하세요.'}
        </div>
      </div>

      <form class="search-results-page__form" method="get" action="/search">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color:var(--color-label-alternative)">
          <circle cx="11" cy="11" r="7" />
          <path d="m20 20-3.5-3.5" />
        </svg>
        <input
          name="q"
          value={trimmed}
          placeholder="다시 검색…"
          autocomplete="off"
        />
        <button type="submit" class="btn btn--primary" style="height:36px;padding:0 14px">
          검색
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7" />
          </svg>
        </button>
      </form>

      {trimmed && results.length === 0 && (
        <div style="padding:64px 24px;border:1px dashed var(--color-line-normal);border-radius:16px;text-align:center;color:var(--color-label-alternative);background:var(--color-bg-alternative);max-width:640px">
          <h3 style="margin:0 0 8px;color:var(--color-label-normal);font-size:18px">
            일치하는 글이 없어요
          </h3>
          <p style="margin:0 0 16px;font-size:14px">
            철자를 확인하거나, 더 짧은 키워드로 다시 시도해보세요.<br/>
            혹은 아래 추천 태그를 살펴봐도 좋아요.
          </p>
          <div style="display:flex;gap:6px;justify-content:center;flex-wrap:wrap">
            {popularTags.map((t) => (
              <a href={`/blog?tag=${encodeURIComponent(t.tag)}`} class="tag">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="opacity:0.55;margin-right:3px">
                  <path d="M4 9h16M4 15h16M10 3 8 21M16 3l-2 18" />
                </svg>
                {t.tag}
              </a>
            ))}
          </div>
        </div>
      )}

      {trimmed && results.length > 0 && (
        <div class="search-results-page__list">
          {resultEntries.map((post) => <ListItem post={post} />)}
        </div>
      )}
    </div>
  </main>
  <Footer />
</BaseLayout>
