---
import SEOHead from '../components/layout/SEOHead.astro';
import '../styles/tokens.css';
import '../styles/app.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  publishDate?: Date | string;
  author?: string;
  tags?: string[];
}

const {
  title,
  description = '홍마초의 잡생각 — dev, invest, learn, daily',
  ogImage,
  publishDate,
  author,
  tags = []
} = Astro.props;
---

<!doctype html>
<html lang="ko" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <SEOHead
      title={title}
      description={description}
      image={ogImage}
      publishDate={publishDate}
      author={author}
      tags={tags}
      type={publishDate ? 'article' : 'website'}
    />

    <!-- Pretendard Variable -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
    />

    <!-- JetBrains Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>

    <!-- FOUC 방지: 테마 및 content-width 복원 (blocking) -->
    <script is:inline>
      (function () {
        try {
          var theme = localStorage.getItem('blog-theme');
          if (!theme) {
            theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          document.documentElement.setAttribute('data-theme', theme);

          var width = localStorage.getItem('blog-content-width');
          if (width) {
            document.documentElement.style.setProperty('--content-width', width);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">메인 콘텐츠로 바로가기</a>
    <div class="app-shell">
      <slot />
    </div>
  </body>
</html>
