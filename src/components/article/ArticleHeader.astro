---
import CategoryBadge from '../ui/CategoryBadge.astro';
import { formatDate } from '../../lib/utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, excerpt, category, date, readTime } = post.data;
---

<header class="article__header">
  <div class="article__meta-top">
    <CategoryBadge category={category} />
    <span style="font-size:13px;color:var(--color-label-alternative)">{formatDate(date)}</span>
    {readTime && (
      <>
        <span style="color:var(--color-line-strong)">·</span>
        <span style="display:inline-flex;gap:4px;align-items:center;color:var(--color-label-alternative);font-size:13px">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
            <path d="M12 6v6l4 2" />
          </svg>
          {readTime}분 읽기
        </span>
      </>
    )}
  </div>
  <h1 class="article__title">{title}</h1>
  {excerpt && <p class="article__excerpt">{excerpt}</p>}
  <div class="article__byline">
    <span class="article__avatar" aria-hidden="true">홍</span>
    <div>
      <div class="article__byline-name">홍마초</div>
      <div class="article__byline-date">작성 · {formatDate(date)}</div>
    </div>
  </div>
</header>
