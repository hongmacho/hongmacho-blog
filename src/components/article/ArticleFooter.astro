---
import PostCard from '../blog/PostCard.astro';
import GiscusComments from '../comments/GiscusComments';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  related: CollectionEntry<'blog'>[];
}

const { post, related } = Astro.props;
const { tags, title } = post.data;
---

<footer class="article__footer">
  <div class="article__share">
    <div class="article__share-tags">
      {tags.map((tag) => (
        <a href={`/blog?tag=${encodeURIComponent(tag)}`} class="tag">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="opacity:0.55;margin-right:3px">
            <path d="M4 9h16M4 15h16M10 3 8 21M16 3l-2 18" />
          </svg>
          {tag}
        </a>
      ))}
    </div>
    <div class="share-actions">
      <button type="button" class="btn btn--ghost" id="copy-link-btn" aria-label="링크 복사">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect width="14" height="14" x="8" y="8" rx="2" />
          <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
        </svg>
        링크 복사
      </button>
      <a class="btn btn--ghost" href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=`} target="_blank" rel="noopener noreferrer">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
        </svg>
        공유
      </a>
    </div>
  </div>

  {related.length > 0 && (
    <div class="related">
      <h2 class="related__title">관련 글</h2>
      <div class="related__grid">
        {related.map((p) => <PostCard post={p} />)}
      </div>
    </div>
  )}

  <div class="article__comments-block">
    <h2 class="related__title">댓글</h2>
    <GiscusComments client:visible articleId={post.id} articleTitle={title} />
  </div>
</footer>

<style>
  .article__comments-block {
    margin-top: 8px;
  }
  .article__comments-block .related__title {
    margin-bottom: 12px;
  }
  /* Let Giscus breathe; remove any extra chrome from the iframe wrapper */
  .article__comments-block :global(#giscus-container) {
    min-height: 200px;
  }
</style>

<script>
  const btn = document.getElementById('copy-link-btn');
  btn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(window.location.href);
      const original = btn.innerHTML;
      btn.innerHTML = '복사됨!';
      setTimeout(() => { btn.innerHTML = original; }, 2000);
    } catch {
      // ignore
    }
  });

  // Append the current URL to the share button href at runtime
  document.querySelectorAll<HTMLAnchorElement>('.share-actions a[href*="twitter.com/intent"]').forEach((a) => {
    a.href = a.href + encodeURIComponent(window.location.href);
  });
</script>
