---
interface TagWithCount {
  tag: string;
  count: number;
}

interface Props {
  tags: TagWithCount[];
  selectedTag: string | null;
}

const { tags, selectedTag } = Astro.props;
const popular = tags.slice(0, 18);
---

<div>
  <div class="sidebar__title">인기 태그</div>
  <div class="sidebar__tag-cloud">
    {popular.map((item) => {
      const active = selectedTag === item.tag;
      return (
        <a
          href={`/blog?tag=${encodeURIComponent(item.tag)}`}
          class="tag"
          style={active ? 'background: var(--color-primary-normal); color: var(--color-primary-on);' : undefined}
        >
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="opacity:0.55;margin-right:3px">
            <path d="M4 9h16M4 15h16M10 3 8 21M16 3l-2 18" />
          </svg>
          {item.tag}
        </a>
      );
    })}
  </div>
</div>
