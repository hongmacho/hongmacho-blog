---
import type { CategoryId } from '../../lib/categories';

interface CategoryWithCount {
  id: string;
  name: string;
  color: string;
  count: number;
}

interface Props {
  categories: CategoryWithCount[];
  selectedCat: CategoryId | null;
}

const { categories, selectedCat } = Astro.props;
const total = categories.reduce((s, c) => s + c.count, 0);
---

<div>
  <div class="sidebar__title">카테고리</div>
  <ul class="sidebar__list">
    <li>
      <a
        href="/blog"
        class:list={['sidebar__item', { 'is-active': !selectedCat }]}
      >
        <span style="display:inline-flex;align-items:center">
          <span class="dot" style="--cat-color: var(--color-label-alternative)"></span>
          전체
        </span>
        <span class="count">{total}</span>
      </a>
    </li>
    {categories.map((cat) => (
      <li>
        <a
          href={`/blog?cat=${cat.id}`}
          class:list={['sidebar__item', { 'is-active': selectedCat === cat.id }]}
          style={`--cat-color: ${cat.color}`}
        >
          <span style="display:inline-flex;align-items:center">
            <span class="dot"></span>
            {cat.name}
          </span>
          <span class="count">{cat.count}</span>
        </a>
      </li>
    ))}
  </ul>
</div>
