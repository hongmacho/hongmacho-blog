---
interface Props {
  pathname: string;
}

const { pathname } = Astro.props;
const isActive = (path: string) =>
  path === '/' ? pathname === '/' : pathname === path || pathname.startsWith(path + '/');
---

<div class="mobile-menu-wrapper">
  <button class="icon-btn mobile-hamburger" id="mobile-menu-btn" aria-label="메뉴 열기" aria-expanded="false" aria-controls="mobile-nav">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="3" y1="6" x2="21" y2="6"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
  </button>

  <nav id="mobile-nav" class="mobile-nav" aria-label="Mobile navigation" hidden>
    <a href="/" class:list={['mobile-nav__link', { 'is-active': isActive('/') }]} aria-current={isActive('/') ? 'page' : undefined}>홈</a>
    <a href="/blog" class:list={['mobile-nav__link', { 'is-active': isActive('/blog') }]} aria-current={isActive('/blog') ? 'page' : undefined}>블로그</a>
    <a href="/about" class:list={['mobile-nav__link', { 'is-active': isActive('/about') }]} aria-current={isActive('/about') ? 'page' : undefined}>소개</a>
  </nav>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const nav = document.getElementById('mobile-nav');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    if (nav) nav.hidden = expanded;
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && btn?.getAttribute('aria-expanded') === 'true') {
      btn.setAttribute('aria-expanded', 'false');
      if (nav) nav.hidden = true;
      btn.focus();
    }
  });
</script>
