---
import ThemeToggle from '../ui/ThemeToggle';
import WidthPicker from '../ui/WidthPicker';
import MobileMenu from './MobileMenu.astro';
import SearchOverlay from '../ui/SearchOverlay';
import { getCollection } from 'astro:content';

const pathname = Astro.url.pathname;
const isActive = (path: string) =>
  path === '/' ? pathname === '/' : pathname === path || pathname.startsWith(path + '/');

// Fetch all blog posts for search
const allPosts = await getCollection('blog');
const blogPosts = allPosts.map((post) => ({
  id: post.id,
  title: post.data.title,
  excerpt: post.data.excerpt,
  category: post.data.category,
  tags: post.data.tags,
  date: post.data.date,
  slug: post.id,
}));
---

<header class="site-header" id="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand" aria-label="홍마초의 잡생각 — 홈으로">
      <span class="brand__badge" aria-hidden="true">
        <span class="brand__rocket">🚀</span>
      </span>
      <span class="brand__wordmark">
        홍마초의 잡생각<span class="brand__dot" aria-hidden="true"></span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <a href="/" class:list={['site-nav__link', { 'is-active': isActive('/') }]}>홈</a>
      <a href="/blog" class:list={['site-nav__link', { 'is-active': isActive('/blog') }]}>블로그</a>
      <a href="/about" class:list={['site-nav__link', { 'is-active': isActive('/about') }]}>소개</a>

      <div class="site-header__tools">
        <button class="icon-btn" id="search-open-btn" aria-label="검색" title="검색 (⌘K)">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>
          </svg>
        </button>
        <WidthPicker client:load />
        <ThemeToggle client:load />
      </div>
    </nav>

    <MobileMenu pathname={pathname} />
  </div>
</header>

<SearchOverlay client:load allPosts={blogPosts} />

<script>
  const header = document.getElementById('site-header');
  if (header) {
    const onScroll = () => {
      header.classList.toggle('scrolled', window.scrollY > 8);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
      e.preventDefault();
      // SearchOverlay Island handles opening the modal via its global keydown listener
    }
  });
</script>
