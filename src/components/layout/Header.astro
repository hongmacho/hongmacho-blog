---
import ThemeToggle from '../ui/ThemeToggle';
import WidthPicker from '../ui/WidthPicker';
import SearchOverlay from '../ui/SearchOverlay';
import MobileMenu from './MobileMenu.astro';
import { getCollection } from 'astro:content';
import { SETTINGS } from '@/lib/settings';

const pathname = Astro.url.pathname;
const brandAria = `${SETTINGS.site.title} — 홈으로`;
const isActive = (path: string) =>
  path === '/' ? pathname === '/' : pathname === path || pathname.startsWith(path + '/');

const allPosts = await getCollection('blog');
const blogPosts = allPosts.map((post) => ({
  id: post.id,
  title: post.data.title,
  excerpt: post.data.excerpt,
  category: post.data.category,
  tags: post.data.tags,
  date: typeof post.data.date === 'string' ? post.data.date : post.data.date.toISOString(),
  slug: post.id,
}));
---

<header class="site-header" id="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand" aria-label={brandAria}>
      <span class="brand__badge" aria-hidden="true">
        <span class="brand__rocket">🚀</span>
      </span>
      <span class="brand__wordmark">
        {SETTINGS.site.title}<span class="brand__dot" aria-hidden="true"></span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <a href="/" class:list={['site-nav__link', { 'is-active': isActive('/') }]} aria-current={isActive('/') ? 'page' : undefined}>홈</a>
      <a href="/blog" class:list={['site-nav__link', { 'is-active': isActive('/blog') }]} aria-current={isActive('/blog') ? 'page' : undefined}>블로그</a>
      <a href="/about" class:list={['site-nav__link', { 'is-active': isActive('/about') }]} aria-current={isActive('/about') ? 'page' : undefined}>소개</a>

      <div class="site-header__tools">
        <button type="button" class="icon-btn" id="search-open-btn" aria-label="검색" title="검색 (⌘K)">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7" />
            <path d="m20 20-3.5-3.5" />
          </svg>
        </button>
        <WidthPicker client:load />
        <ThemeToggle client:load />
      </div>
    </nav>

    <button type="button" class="site-header__menu-btn" id="mobile-menu-btn" aria-label="메뉴 열기" aria-expanded="false" aria-controls="mobile-menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>
</header>

<MobileMenu pathname={pathname} />

<SearchOverlay client:load allPosts={blogPosts} />

<script>
  const header = document.getElementById('site-header');
  if (header) {
    const onScroll = () => {
      header.classList.toggle('scrolled', window.scrollY > 8);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  const openSearch = () => {
    document.dispatchEvent(new CustomEvent('hongmacho:open-search'));
  };
  document.getElementById('search-open-btn')?.addEventListener('click', openSearch);
  document.getElementById('mobile-search-btn')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('hongmacho:close-mobile-menu'));
    openSearch();
  });
</script>
