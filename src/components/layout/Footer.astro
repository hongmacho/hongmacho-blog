---
import { CATEGORY_LIST } from '../../lib/categories';

const buildDate = new Date().toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <!-- Brand block -->
    <div class="site-footer__brand-block">
      <a href="/" class="brand" aria-label="홍마초의 잡생각 — 홈으로">
        <span class="brand__badge" aria-hidden="true">
          <span class="brand__rocket">🚀</span>
        </span>
        <span class="brand__wordmark">
          홍마초의 잡생각<span class="brand__dot" aria-hidden="true"></span>
        </span>
      </a>
      <p class="site-footer__tagline">개발, 투자, 학습 그리고 일상의 기록.</p>
      <div style="display:flex;gap:6px;margin-top:4px">
        <a class="icon-btn" href="https://github.com/hongmacho" aria-label="GitHub" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
          </svg>
        </a>
        <a class="icon-btn" href="https://x.com/hongmacho" aria-label="X / Twitter" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a class="icon-btn" href="/feed.xml" aria-label="RSS 피드" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 11a9 9 0 0 1 9 9M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Explore -->
    <div>
      <div class="site-footer__col-title">Explore</div>
      <ul class="site-footer__list">
        <li><a href="/blog">전체 글</a></li>
        {CATEGORY_LIST.map((cat) => (
          <li><a href={`/blog?cat=${cat.id}`}>{cat.name}</a></li>
        ))}
      </ul>
    </div>

    <!-- More -->
    <div>
      <div class="site-footer__col-title">More</div>
      <ul class="site-footer__list">
        <li><a href="/about">About</a></li>
        <li><a href="/feed.xml">RSS</a></li>
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="container site-footer__bottom">
    <span>© 2026 홍마초</span>
    <span class="site-footer__build-date">{buildDate} 빌드</span>
    <span class="site-footer__version" style="font-family:monospace;font-size:11px;background:var(--surface-2,rgba(0,0,0,0.06));padding:2px 8px;border-radius:99px">v1.0.0</span>
  </div>
</footer>
