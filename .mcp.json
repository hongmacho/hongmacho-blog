{
  "mcpServers": {
    "shrimp-task-manager": {
      "command": "npx",
      "args": ["-y", "mcp-shrimp-task-manager@1.0.21"],
      "env": {
        "DATA_DIR": "/Users/hongpaul/develop/project-persnol/hongmacho-blog/.shrimp",
        "TEMPLATES_USE": "en",
        "ENABLE_GUI": "false",
        "PROMPT_LANGUAGE": "ko"
      }
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "env": {}
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    }
  }
